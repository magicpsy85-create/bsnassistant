{
  "hosting": {
    "public": "public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "function": "api"
      }
    ]
  },
  "functions": {
    "source": ".",
    "runtime": "nodejs22",
    "ignore": [
      "node_modules",
      ".git",
      "scripts",
      "data/transactions.db*",
      "명단.CSV",
      "*.json.bak"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
