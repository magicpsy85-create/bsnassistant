# === BSN Assistant 환경 변수 ===
# .env 파일을 만들 때 이 파일을 복사해서 사용하세요: cp env.example .env

# --- 핵심 API ---
OPENAI_API_KEY=sk-...
FB_WEB_API_KEY=AIza...

# --- 부동산 데이터 ---
MOLIT_API_KEY=...

# --- 검색·뉴스 ---
# Brave Search: 실거래가 인사이트(/api/transaction/insight) + 리포트(/api/transaction/report) LLM Context·Places·뉴스 fallback
BRAVE_API_KEY=...
# Naver Search: 콘텐츠 생성 doResearch + 추천 뉴스(/api/content/recommend-news) + 실거래가 인사이트·리포트 메인
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...

# --- Cloud Functions ---
FUNCTION_URL=https://...

# --- 미사용 (차후 부활 예정) ---
# 트렌드 모니터링 기능(archive/trend-monitor.ts) 부활 시 활용
# YOUTUBE_API_KEY=...
# 메일 알림 기능 부활 시 활용
# GMAIL_APP_PASSWORD=...
