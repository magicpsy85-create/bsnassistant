# BSN Assistant 환경 변수 설정
# 이 파일을 .env로 복사한 뒤 실제 키를 입력하세요.

# ─── OpenAI ───
# GPT-5 (콘텐츠 생성), GPT-4o (챗봇, AI분석)
OPENAI_API_KEY=sk-...

# ─── Firebase ───
# Firebase 웹 API 키 (클라이언트 인증용)
FB_WEB_API_KEY=AIza...

# ─── 국토교통부 ───
# 실거래가 API (공공데이터포털에서 발급)
# https://www.data.go.kr/data/15058747/openapi.do
MOLIT_API_KEY=...

# ─── Brave Search ───
# 웹 검색 API (AI 분석 보강, 콘텐츠 리서치)
# https://api-dashboard.search.brave.com
BRAVE_API_KEY=BSA...

# ─── 네이버 ───
# 뉴스 검색 API (콘텐츠 리서치, 뉴스 추천)
# https://developers.naver.com/apps
NAVER_CLIENT_ID=...
NAVER_CLIENT_SECRET=...

# ─── 카카오 ───
# REST API 키 (지오코딩)
KAKAO_REST_API_KEY=...
# JS API 키 (카카오맵 렌더링)
KAKAO_JS_API_KEY=...

# ─── Google Gemini (선택) ───
# 이미지 생성 등 (현재 미사용)
# GEMINI_API_KEY=...

# ─── YouTube (선택) ───
# 트렌드 모니터링 (현재 미사용)
# YOUTUBE_API_KEY=...
